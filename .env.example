# =============================================================================
# ChatGPT Data Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:  cp .env.example .env

# --- Kafka ---
KAFKA_BROKER=kafka:9092
KAFKA_BROKER_EXTERNAL=localhost:29092

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_CONSOLE_PORT=9001

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=CHATGPT_PLATFORM
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True
AIRFLOW_UID=50000

# --- Generator Defaults ---
GENERATOR_NUM_USERS=1000
GENERATOR_EVENTS_PER_SECOND=50
